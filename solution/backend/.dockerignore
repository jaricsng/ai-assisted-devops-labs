.DS_Store
*.swp
*.swo
.idea/
.vscode/
*.iml

# Secrets — never bake into image
.env
.env.*
!.env.example

# Git history
.git/
.gitignore

# CI artifacts
.github/

# Local dev overrides
docker-compose.yml
docker-compose*.yml
