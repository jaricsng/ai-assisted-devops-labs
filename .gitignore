# ── Environment ──────────────────────────────────────────────────────────────
# Real credentials live only in .env — never committed.
# .env.example IS committed — it contains only placeholder values.
.env
.env.local
.env.*.local

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
*.egg-info/
# pyenv version file (personal, not team-shared)
.python-version

# Test and coverage artifacts
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/

# Type-checker and linter caches
.mypy_cache/
.ruff_cache/

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
# TypeScript incremental compilation cache (generated by tsc -b / npm run build)
*.tsbuildinfo
# npm and ESLint runtime caches
npm-debug.log*
.eslintcache

# ── Build outputs (Python + Node) ────────────────────────────────────────────
# Matches dist/, build/, coverage/ anywhere in the tree (backend and frontend).
dist/
build/
coverage/

# ── Playwright (E2E) ─────────────────────────────────────────────────────────
playwright-report/
test-results/
/frontend/e2e/.auth/

# ── Pen-test and load-test outputs ───────────────────────────────────────────
# ZAP HTML + JSON reports generated by pen-tests/zap-scan.sh.
# Ignore report files but NOT the directory itself — pen-tests/reports/.gitkeep
# tracks the directory in git so ZAP has a target on fresh clones.
pen-tests/reports/*.html
pen-tests/reports/*.json
pen-tests/reports/*.xml
# k6 summary JSON output (--summary-export flag)
k6-summary*.json
# Locust CSV/HTML output (--csv and --html flags)
locust-results*/
locust_report.html

# ── Security scanning artifacts ───────────────────────────────────────────────
# NOTE: .secrets.baseline IS committed — it records acknowledged false-positives
# so detect-secrets does not re-alert on them after the team has reviewed them.
bandit-report.json
bandit-report.txt
pip-audit-report.json
pip-audit-report.txt
npm-audit-report.json
# SARIF reports (uploaded to GitHub Security tab via codeql-action/upload-sarif)
*.sarif
trivy-results*.json
# SBOM files generated by anchore/sbom-action in publish.yml
sbom-*.json

# Cryptographic material — should never be in the repo under any circumstances
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# ── Claude Code ───────────────────────────────────────────────────────────────
# .claude/commands/ and CLAUDE.md ARE committed — they are team-shared project skills.
# settings.local.json is personal (overrides for one developer only).
# todos/ is session-scoped scratch space, not persistent state.
.claude/settings.local.json
.claude/todos/

# ── Docker / Observability ────────────────────────────────────────────────────
# Named Docker volumes (postgres_data, grafana_data) are managed by Docker.
# Guard against a bind-mount being created accidentally.
postgres_data/
grafana_data/
# Local Docker Compose overrides (developer-specific port mappings, volume paths, etc.)
docker-compose.override.yml

# ── .NET Aspire & Azure Developer CLI ────────────────────────────────────────
# Build artifacts from dotnet build / dotnet run (one bin/ and obj/ per project)
aspire/**/bin/
aspire/**/obj/
# Personal Visual Studio / Rider settings (not team-shared)
aspire/**/*.user
.vs/
# Generated cloud deployment manifest (created by --publisher manifest flag)
aspire-manifest.json
# azd environment state — subscription IDs, env names written by `azd up`.
# azure.yaml IS committed (project config); .azure/ is local generated state.
.azure/

# ── Terraform (Module 17) ────────────────────────────────────────────────────
# Local state files contain resource IDs and may contain secrets — never commit.
# Remote state (S3 / GCS / Azure Blob) is used in production; state files are
# generated locally only during `terraform plan` with a local backend.
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
# Variable files may contain secrets — use .tfvars.example for templates.
*.tfvars
*.tfvars.json
# Override files are local-only customisations on top of the shared config.
override.tf
override.tf.json
*_override.tf
*_override.tf.json
# Terraform plan output (binary — not human-readable; store in CI artifacts, not git)
*.tfplan

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Database files ────────────────────────────────────────────────────────────
# alembic.ini IS committed — credentials come from the DATABASE_URL env var, not inline.
# SQLite files are transient test databases; PostgreSQL state lives in the Docker volume.
*.db
*.sqlite

# ── IDE and OS ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
